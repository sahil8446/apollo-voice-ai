# ---- App ----
ENVIRONMENT=dev                 # dev | staging | prod
LOG_LEVEL=INFO
CORS_ORIGINS=*                  # comma-separated in prod, e.g. https://admin.example.com

# ---- Database ----
# Local docker-compose default; Railway/Render inject their own DATABASE_URL.
# Both postgres:// and postgresql:// are auto-normalized to asyncpg.
DATABASE_URL=postgresql+asyncpg://apollo:apollo@localhost:5432/apollo_voice
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- Security ----
# Retell webhook signing secret (the Retell API key). Leave verification OFF in
# dev so the eval harness and local calls work without a real signature.
RETELL_API_KEY=
VERIFY_RETELL_SIGNATURE=false
# Key the admin dashboard must send as X-API-Key. CHANGE THIS in prod.
ADMIN_API_KEY=dev-admin-key-change-me

# ---- Domain ----
CLINIC_TIMEZONE=Asia/Kolkata
SLOT_MINUTES=15
SLOT_HORIZON_DAYS=21

# ---- Email confirmations (Gmail SMTP) ----
# Leave blank to disable email entirely (booking still works).
# Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Optional: a fixed address (clinic front desk) that gets a copy of every booking.
CLINIC_NOTIFY_EMAIL=
